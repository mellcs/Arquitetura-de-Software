generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pagamento {
  id        Int      @id @default(autoincrement())
  pedidoId  Int
  metodo    String
  valor     Float
  sucesso   Boolean
  criadoEm  DateTime @default(now())
}
